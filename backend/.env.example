SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
BOT_TOKEN=
JWT_SECRET=
PORT=3000

# Optional. Comma-separated Telegram user ids that get access to the
# cross-tenant platform admin panel, regardless of organization membership.
PLATFORM_ADMIN_TELEGRAM_IDS=

# Optional. Restricts CORS to this origin in production (e.g. https://your-app.vercel.app).
# Leave unset for local development to allow any origin.
FRONTEND_ORIGIN=

# Optional. How often (ms) the overdue-checklist notifier runs. Defaults to 300000 (5 min).
OVERDUE_CHECK_INTERVAL_MS=

# Optional. How often (ms) the auto-assign checker runs. Defaults to 300000 (5 min).
AUTO_ASSIGN_CHECK_INTERVAL_MS=
